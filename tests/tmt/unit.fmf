require:
    - git
    - glibc-static
    - golang
    - make
    - btrfs-progs-devel
    - containers-common
    - device-mapper-devel
    - gpgme-devel
    - libassuan-devel
    - libseccomp-devel
    - netavark
    - systemd-devel

summary: Unit tests
test: cd $(git rev-parse --show-toplevel) && make test-unit
duration: 90m
